# ======================
# Auth0 (nextjs-auth0 v4)
# ======================
# Auth0 Dashboard → Applications → Your App → Settings
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_SECRET=a-random-32-character-string-here

# Base URL of your app (used for callback URLs)
APP_BASE_URL=http://localhost:3000

# ======================
# Auth0 AI (M2M Application)
# ======================
# Separate Machine-to-Machine app in Auth0 for CIBA / Token Vault
AUTH0_AI_CLIENT_ID=your_m2m_client_id
AUTH0_AI_CLIENT_SECRET=your_m2m_client_secret

# ======================
# Database (Neon PostgreSQL)
# ======================
# Neon Dashboard → Your Project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ======================
# LLM (Groq — free!)
# ======================
# console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key

# ======================
# LLM (OpenAI — optional, for final demo)
# ======================
# platform.openai.com → API Keys
# OPENAI_API_KEY=sk-your-openai-api-key
